# Application
PORT=8000
NODE_ENV=development
FRONT_URL=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@host:port/dbname"

# JWT Config (Générer des chaînes aléatoires sécurisées)
ACCESS_TOKEN_SECRET="generer_un_secret_robuste_ici"
REFRESH_TOKEN_SECRET="generer_un_secret_robuste_ici"
ACCESS_TOKEN_EXPIRY="15m"
REFRESH_TOKEN_EXPIRY="7d"

# JWT Propriétaires
OWNER_ACCESS_TOKEN_SECRET="generer_un_secret_robuste_ici_owner"
OWNER_REFRESH_TOKEN_SECRET="generer_un_secret_robuste_owner_refresh"
OWNER_ACCESS_TOKEN_EXPIRY="15m"
OWNER_REFRESH_TOKEN_EXPIRY="30d"

# JWT Locataires
LOCATAIRE_ACCESS_TOKEN_SECRET="generer_un_secret_robuste_ici_locataire"
LOCATAIRE_REFRESH_TOKEN_SECRET="generer_un_secret_robuste_locataire_refresh"
LOCATAIRE_ACCESS_TOKEN_EXPIRY="15m"
LOCATAIRE_REFRESH_TOKEN_EXPIRY="30d"

# JWT Comptes Publics
COMPTE_PUBLIC_ACCESS_TOKEN_SECRET="generer_un_secret_robuste_ici_public"
COMPTE_PUBLIC_REFRESH_TOKEN_SECRET="generer_un_secret_robuste_public_refresh"
COMPTE_PUBLIC_ACCESS_TOKEN_EXPIRY="15m"
COMPTE_PUBLIC_REFRESH_TOKEN_EXPIRY="30d"

# Email SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre_email@gmail.com
SMTP_PASS=votre_mot_de_passe_d_application
EMAIL_FROM="Seek <noreply@seek.sn>"

# SMS Twilio
TWILIO_ACCOUNT_SID=votre_sid
TWILIO_AUTH_TOKEN=votre_token
TWILIO_PHONE_NUMBER=votre_numero

# OTP Configuration
OTP_EXPIRES_IN_MINUTES=10

# Cloudinary
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

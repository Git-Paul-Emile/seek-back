// ─── Formulaire Dynamique ─────────────────────────────────────────────────────

enum TypeChamp {
  TEXTE
  NOMBRE
  SURFACE
  PRIX
  BOOLEEN
  SELECT
  DATE
}

model CategorieChamp {
  id        String   @id @default(uuid())
  nom       String   @unique
  ordre     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  champs    Champ[]
}

model Champ {
  id           String              @id @default(uuid())
  nom          String
  type         TypeChamp
  unite        String?
  options      String[]
  categorieId  String
  actif        Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  categorie    CategorieChamp      @relation(fields: [categorieId], references: [id])
  typeLogements TypeLogementChamp[]
  biensValeurs  BienChampValeur[]

  @@unique([nom, categorieId])
  @@index([categorieId])
}

model TypeLogementChamp {
  typeLogementId String
  champId        String
  obligatoire    Boolean      @default(false)
  ordre          Int          @default(0)
  typeLogement   TypeLogement @relation(fields: [typeLogementId], references: [id], onDelete: Cascade)
  champ          Champ        @relation(fields: [champId], references: [id], onDelete: Cascade)

  @@unique([typeLogementId, champId])
  @@index([typeLogementId])
}

model BienChampValeur {
  id      String @id @default(uuid())
  bienId  String
  champId String
  valeur  String
  bien    Bien   @relation(fields: [bienId], references: [id], onDelete: Cascade)
  champ   Champ  @relation(fields: [champId], references: [id], onDelete: Cascade)

  @@unique([bienId, champId])
  @@index([bienId])
}

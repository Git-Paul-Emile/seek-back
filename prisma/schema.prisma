generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// MODÈLES GÉOGRAPHIQUES
// ============================================================

model Pays {
  id        String   @id @default(uuid())
  nom       String   @unique
  code      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  villes Ville[]
}

model Ville {
  id        String   @id @default(uuid())
  nom       String
  paysId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pays      Pays       @relation(fields: [paysId], references: [id])
  quartiers Quartier[]

  @@unique([nom, paysId])
}

model Quartier {
  id        String   @id @default(uuid())
  nom       String
  villeId   String
  latitude  Float
  longitude Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ville Ville  @relation(fields: [villeId], references: [id])
  biens Bien[]

  @@unique([nom, villeId])
  @@index([villeId])
}

// ============================================================
// BIENS IMMOBILIERS
// ============================================================

model TypeLogement {
  id        String   @id @default(uuid())
  nom       String   @unique
  slug      String   @unique
  image     String?
  actif     Boolean  @default(true)
  ordre     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  biens Bien[]

  @@index([slug])
}

model TypeTransaction {
  id        String   @id @default(uuid())
  nom       String   @unique
  slug      String   @unique
  actif     Boolean  @default(true)
  ordre     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  biens Bien[]

  @@index([slug])
}

model StatutBien {
  id        String   @id @default(uuid())
  nom       String   @unique
  slug      String   @unique
  actif     Boolean  @default(true)
  ordre     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  biens Bien[]

  @@index([slug])
}

// ============================================================
// CATÉGORIES MEUBLÉ / ÉQUIPEMENT
// ============================================================

model CategorieMeuble {
  id        String   @id @default(uuid())
  nom       String   @unique
  slug      String   @unique
  actif     Boolean  @default(true)
  ordre     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  meubles Meuble[]

  @@index([slug])
}

model CategorieEquipement {
  id        String   @id @default(uuid())
  nom       String   @unique
  slug      String   @unique
  actif     Boolean  @default(true)
  ordre     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  equipements Equipement[]

  @@index([slug])
}

model Meuble {
  id          String   @id @default(uuid())
  nom         String
  categorieId String
  actif       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categorie CategorieMeuble @relation(fields: [categorieId], references: [id])
  biens     BienMeuble[]

  @@unique([nom, categorieId])
  @@index([categorieId])
}

model Equipement {
  id          String   @id @default(uuid())
  nom         String
  categorieId String
  actif       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categorie CategorieEquipement @relation(fields: [categorieId], references: [id])
  biens     BienEquipement[]

  @@unique([nom, categorieId])
  @@index([categorieId])
}

// ============================================================
// FORMULES PREMIUM (admin configurable)
// ============================================================

model FormulePremium {
  id          String   @id @default(uuid())
  code        String   @unique
  nom         String
  dureeJours  Int
  prix        Float
  accroche    String
  description String
  idealPour   String[]
  populer     Boolean  @default(false)
  actif       Boolean  @default(true)
  ordre       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// BIENS
// ============================================================

enum StatutAnnonce {
  BROUILLON
  EN_ATTENTE
  PUBLIE
  REJETE
  ANNULE
}

model Bien {
  id                String  @id @default(uuid())
  titre             String?
  description       String?
  typeLogementId    String?
  typeTransactionId String?
  statutBienId      String?
  proprietaireId    String

  // Localisation
  pays        String?
  region      String?
  ville       String?
  quartier    String?
  quartierId  String?
  adresse     String?
  pointRepere String?
  latitude    Float?
  longitude   Float?

  // Caractéristiques
  surface          Float?
  surfaceParcelle  Float?
  nbChambres       Int?
  nbSdb            Int?
  nbSalons         Int?
  nbCuisines       Int?
  etage            Int?
  nbEtages         Int?
  nbAppartements   Int?
  nbPieces         Int?
  nbWc             Int?
  typeTerrain      String?
  cloture          Boolean @default(false)
  typeBureau       String?
  rideauMetallique Boolean @default(false)

  // Options
  meuble    Boolean @default(false)
  fumeurs   Boolean @default(false)
  animaux   Boolean @default(false)
  parking   Boolean @default(false)
  ascenseur Boolean @default(false)

  // Prix
  prix                         Float?
  prixAncien                   Float? // Prix précédent (pour calculer la baisse)
  dateDerniereModificationPrix DateTime? // Date de la dernière modification de prix
  frequencePaiement            String?
  chargesIncluses              Boolean   @default(false)
  caution                      Int?
  disponibleLe                 DateTime?

  // Médias
  photos String[]

  // Statistiques
  nbVues    Int @default(0)
  nbFavoris Int @default(0)

  // État & Publication
  actif         Boolean       @default(true)
  statutAnnonce StatutAnnonce @default(BROUILLON)
  noteAdmin     String?

  // Promotion / Mise en avant
  estPremium         Boolean   @default(false)
  estMisEnAvant      Boolean   @default(false)
  dateDebutPromotion DateTime?
  dateFinPromotion   DateTime?
  positionRotation   Int       @default(0) // Position dans la rotation
  dernierAffichage   DateTime? // Dernière fois où l'annonce a été affichée en page d'accueil

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  typeLogement    TypeLogement?    @relation(fields: [typeLogementId], references: [id])
  typeTransaction TypeTransaction? @relation(fields: [typeTransactionId], references: [id])
  statutBien      StatutBien?      @relation(fields: [statutBienId], references: [id])
  proprietaire    Proprietaire     @relation(fields: [proprietaireId], references: [id], onDelete: Cascade)
  quartierRel     Quartier?        @relation(fields: [quartierId], references: [id])

  equipements        BienEquipement[]
  meubles            BienMeuble[]
  etablissements     Etablissement[]
  bails              BailLocation[]
  transactions       Transaction[]
  promotionHistories PromotionHistory[]
  documents          DocumentBien[]
  favoris            Favori[]
  vues               VueBien[]
  bailInvitations    BailInvitation[]
  signalements       Signalement[]
  etatsDesLieux      EtatDesLieux[]

  @@index([proprietaireId])
  @@index([typeLogementId])
  @@index([typeTransactionId])
  @@index([statutBienId])
  @@index([statutAnnonce])
  @@index([actif])
  @@index([createdAt])
  // Index composites pour les requêtes fréquentes
  @@index([statutAnnonce, actif])
  @@index([statutAnnonce, createdAt])
  @@index([statutAnnonce, ville])
  @@index([statutAnnonce, typeLogementId])
  @@index([statutAnnonce, typeTransactionId])
  @@index([statutAnnonce, prix])
  @@index([ville, quartier])
  @@index([latitude, longitude])
}

model ComptePublic {
  id        String   @id @default(uuid())
  nom       String
  prenom    String
  telephone String   @unique
  email     String?  @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  favoris       Favori[]
  refreshTokens ComptePublicRefreshToken[]
  signalements  Signalement[]
}

model ComptePublicRefreshToken {
  id             String    @id @default(uuid())
  comptePublicId String
  tokenHash      String    @unique
  expiresAt      DateTime
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())

  comptePublic ComptePublic @relation(fields: [comptePublicId], references: [id], onDelete: Cascade)

  @@index([comptePublicId])
  @@index([tokenHash])
}

model Favori {
  id             String @id @default(uuid())
  comptePublicId String
  bienId         String

  // Snapshot pour détecter les changements (suivi prix/statut)
  prixSnapshot   Float?
  statutSnapshot String? // slug du statut
  actifSnapshot  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comptePublic ComptePublic @relation(fields: [comptePublicId], references: [id], onDelete: Cascade)
  bien         Bien         @relation(fields: [bienId], references: [id], onDelete: Cascade)

  @@unique([comptePublicId, bienId])
  @@index([comptePublicId])
}

model VueBien {
  id        String  @id @default(uuid())
  bienId    String
  userId    String? // ComptePublic id (nullable — visiteur anonyme)
  ipAddress String

  createdAt DateTime @default(now())

  bien Bien @relation(fields: [bienId], references: [id], onDelete: Cascade)

  @@index([bienId])
  @@index([bienId, createdAt])
  @@index([ipAddress, bienId])
}

model BienEquipement {
  bienId       String
  equipementId String

  bien       Bien       @relation(fields: [bienId], references: [id], onDelete: Cascade)
  equipement Equipement @relation(fields: [equipementId], references: [id])

  @@unique([bienId, equipementId])
}

model BienMeuble {
  bienId   String
  meubleId String
  quantite Int    @default(1)

  bien   Bien   @relation(fields: [bienId], references: [id], onDelete: Cascade)
  meuble Meuble @relation(fields: [meubleId], references: [id])

  @@unique([bienId, meubleId])
}

// ============================================================
// DOCUMENTS D'UN BIEN
// ============================================================

model DocumentBien {
  id             String   @id @default(uuid())
  bienId         String
  proprietaireId String
  nom            String
  type           String // "ACTE_PROPRIETE" | "PLAN_CADASTRAL" | "PERMIS_CONSTRUIRE" | "AUTRE"
  url            String
  taille         Int? // en octets
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  bien         Bien         @relation(fields: [bienId], references: [id], onDelete: Cascade)
  proprietaire Proprietaire @relation(fields: [proprietaireId], references: [id], onDelete: Cascade)

  @@index([bienId])
  @@index([proprietaireId])
}

// ============================================================
// ÉTABLISSEMENTS PROCHES
// ============================================================

model Etablissement {
  id        String   @id @default(uuid())
  bienId    String
  type      String
  nom       String?
  latitude  Float
  longitude Float
  distance  Float?
  createdAt DateTime @default(now())

  bien Bien @relation(fields: [bienId], references: [id], onDelete: Cascade)

  @@index([bienId])
  @@index([type])
}

// ============================================================
// LOCATAIRES
// ============================================================

enum StatutLocataire {
  INVITE
  ACTIF
  INACTIF
  ANCIEN
}

enum StatutBail {
  EN_ATTENTE // En attente de validation du contrat
  ACTIF
  EN_PREAVIS
  EN_RENOUVELLEMENT
  TERMINE
  RESILIE
  ARCHIVE
}

enum TypePieceIdentite {
  CNI
  PASSEPORT
  CARTE_CONSULAIRE
  AUTRE
}

model Locataire {
  id             String @id @default(uuid())
  proprietaireId String

  // Rempli par le propriétaire
  nom             String
  prenom          String
  telephone       String
  email           String?
  nbOccupants     Int     @default(1)
  presenceEnfants Boolean @default(false)

  // Rempli par le locataire après activation
  dateNaissance            DateTime?
  lieuNaissance            String?
  nationalite              String?
  sexe                     String?
  numPieceIdentite         String?
  typePiece                TypePieceIdentite?
  dateDelivrance           DateTime?
  dateExpirationPiece      DateTime?
  autoriteDelivrance       String?
  situationProfessionnelle String?

  // Activation
  activationToken String?         @unique
  tokenExpiresAt  DateTime?
  statut          StatutLocataire @default(INVITE)
  password        String?

  // Suspension
  estSuspendu     Boolean   @default(false)
  motifSuspension String?
  dateSuspension  DateTime?
  suspenduPar     String?

  // Vérification
  verification LocataireVerification?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  proprietaire        Proprietaire                  @relation(fields: [proprietaireId], references: [id], onDelete: Cascade)
  bails               BailLocation[]
  refreshTokens       LocataireRefreshToken[]
  passwordResetTokens LocatairePasswordResetToken[]
  transactions        Transaction[]
  messagesInternes    MessageInterneLocataire[]
  bailInvitations     BailInvitation[]
  etatsDesLieux       EtatDesLieux[]

  @@index([proprietaireId])
  @@index([activationToken])
}

// ============================================================
// VÉRIFICATION LOCATAIRE
// ============================================================

enum StatutVerificationLocataire {
  NOT_VERIFIED
  PENDING
  VERIFIED
  REJECTED
}

model LocataireVerification {
  id          String @id @default(uuid())
  locataireId String @unique

  // Type de pièce d'identité
  typePiece String @default("CNI") // CNI | PASSEPORT | CARTE_CONSULAIRE | AUTRE

  // Documents
  pieceIdentiteRecto String? // URL Cloudinary - recto
  pieceIdentiteVerso String? // URL Cloudinary - verso (pour CNI)
  selfie             String? // URL Cloudinary

  // Statut
  statut StatutVerificationLocataire @default(NOT_VERIFIED)

  // Consentement
  conditionsAcceptees Boolean @default(false)

  // Traitement propriétaire
  motifRejet     String? // Motif de rejet (si rejeté)
  traitePar      String? // ID du propriétaire qui a traité
  dateTraitement DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  locataire Locataire @relation(fields: [locataireId], references: [id], onDelete: Cascade)
}

model BailLocation {
  id             String @id @default(uuid())
  bienId         String
  locataireId    String
  proprietaireId String

  typeBail           String?
  dateDebutBail      DateTime
  dateFinBail        DateTime?
  renouvellement     Boolean    @default(false)
  montantLoyer       Float
  montantCaution     Float?
  cautionVersee      Boolean    @default(false)
  jourLimitePaiement Int?
  delaiGrace         Int        @default(5)
  frequencePaiement  String?
  statut             StatutBail @default(EN_ATTENTE)
  motifResiliation   String?
  initiePar          String? // "PROPRIETAIRE" | "LOCATAIRE"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bien          Bien              @relation(fields: [bienId], references: [id], onDelete: Cascade)
  locataire     Locataire         @relation(fields: [locataireId], references: [id], onDelete: Cascade)
  proprietaire  Proprietaire      @relation(fields: [proprietaireId], references: [id])
  contrat       Contrat?
  echeancier    EcheancierLoyer[]
  depotCaution  DepotCaution?
  transactions  Transaction[]
  etatsDesLieux EtatDesLieux[]

  @@index([bienId])
  @@index([locataireId])
  @@index([proprietaireId])
  @@index([statut])
}

// ============================================================
// SUIVI FINANCIER
// ============================================================

enum StatutPaiement {
  A_VENIR // Échéance future — pas encore due
  EN_ATTENTE // Due ce mois-ci (dans la période de grâce)
  EN_RETARD // Non payée après la période de grâce
  EN_ATTENTE_CONFIRMATION // Paiement espèces enregistré par le propriétaire, en attente confirmation locataire
  PAYE // Intégralement payée
  ANNULE // Annulée
}

model EcheancierLoyer {
  id             String @id @default(uuid())
  bailId         String
  bienId         String
  proprietaireId String
  locataireId    String

  dateEcheance DateTime
  montant      Float // Loyer seul
  statut       StatutPaiement @default(A_VENIR)

  datePaiement         DateTime?
  modePaiement         String?
  reference            String?
  note                 String?
  sourceEnregistrement String? // "LOCATAIRE" | "PROPRIETAIRE"

  commissionTaux    Float? // Taux commission au moment du paiement
  commissionMontant Float? // Montant commission prélevé
  montantNet        Float? // Montant reçu par le propriétaire (montant - commissionMontant)

  confirmeParProprietaire   Boolean   @default(false)
  dateConfirmation          DateTime?
  confirmeParLocataire      Boolean   @default(false)
  dateConfirmationLocataire DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bail         BailLocation  @relation(fields: [bailId], references: [id], onDelete: Cascade)
  quittance    Quittance?
  transactions Transaction[]

  @@index([bailId])
  @@index([bienId])
  @@index([statut])
  @@index([dateEcheance])
}

// ============================================================
// QUITTANCES
// ============================================================

model Quittance {
  id             String @id @default(uuid())
  echeanceId     String @unique
  bailId         String
  bienId         String
  proprietaireId String
  locataireId    String
  numero         String

  dateGeneration DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  echeance EcheancierLoyer @relation(fields: [echeanceId], references: [id], onDelete: Cascade)

  @@index([bailId])
  @@index([bienId])
  @@index([locataireId])
}

// ============================================================
// NOTIFICATIONS
// ============================================================

enum StatutNotification {
  EN_ATTENTE
  ENVOYE
  ECHEC
}

enum TypeNotification {
  RAPPEL_LOYER
  CONFIRMATION_PAIEMENT
  ALERTE_RETARD
  INITIATION_PAIEMENT
  VERIFICATION_LOCATAIRE
  PAIEMENT_LOCATAIRE // Propriétaire notifié quand le locataire enregistre un paiement
  PREAVIS // Préavis de fin de bail
  RESILIATION // Résiliation du bail
  FIN_BAIL // Clôture du bail
  CONTRAT // Transmission du contrat de bail
  RESET_PASSWORD // Réinitialisation mot de passe
  ALERTE // Alerte nouvelle annonce (grand public)
  VERIFICATION_TELEPHONE // Vérification téléphone lors de l'inscription
  PAIEMENT_ESPECES_LOCATAIRE // Locataire notifié quand le propriétaire enregistre un paiement espèces
  CONFIRMATION_ESPECES_PROPRIETAIRE // Propriétaire notifié quand le locataire confirme un paiement espèces
  ETAT_DES_LIEUX_DISPONIBLE
  ETAT_DES_LIEUX_VALIDE
  ETAT_DES_LIEUX_MODIFIE
}

model Notification {
  id            String             @id @default(uuid())
  type          TypeNotification
  canal         String             @default("SMS") // SMS | EMAIL | WHATSAPP
  destinataire  String // numéro ou email
  sujet         String?
  contenu       String
  statut        StatutNotification @default(EN_ATTENTE)
  messageRetour String? // réponse de l'API externe (stub: message)

  echeanceId     String?
  bailId         String?
  bienId         String?
  proprietaireId String?
  locataireId    String?

  envoyeAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([bailId])
  @@index([echeanceId])
  @@index([locataireId])
  @@index([type])
  @@index([statut])
}

enum StatutDepot {
  RECU
  RESTITUE
  PARTIELLEMENT_RESTITUE
  RETENU
}

model DepotCaution {
  id             String @id @default(uuid())
  bailId         String @unique
  bienId         String
  proprietaireId String
  locataireId    String

  montant       Float
  statut        StatutDepot @default(RECU)
  dateReception DateTime    @default(now())

  dateRestitution DateTime?
  montantRestitue Float?
  motifRetenue    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bail BailLocation @relation(fields: [bailId], references: [id], onDelete: Cascade)

  @@index([bailId])
  @@index([bienId])
}

// ============================================================
// CONTRATS
// ============================================================

enum StatutContrat {
  BROUILLON
  ACTIF
  ARCHIVE
}

model ModeleContrat {
  id        String   @id @default(uuid())
  titre     String
  typeBail  String?
  contenu   String   @db.Text
  actif     Boolean  @default(true)
  ordre     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contrats Contrat[]
}

model Contrat {
  id        String        @id @default(uuid())
  bailId    String        @unique
  modeleId  String?
  titre     String
  contenu   String        @db.Text
  statut    StatutContrat @default(BROUILLON)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  bail   BailLocation   @relation(fields: [bailId], references: [id], onDelete: Cascade)
  modele ModeleContrat? @relation(fields: [modeleId], references: [id], onDelete: SetNull)

  @@index([bailId])
  @@index([modeleId])
}

model LocataireRefreshToken {
  id          String    @id @default(uuid())
  locataireId String
  tokenHash   String    @unique
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  locataire Locataire @relation(fields: [locataireId], references: [id], onDelete: Cascade)

  @@index([locataireId])
  @@index([tokenHash])
}

model LocatairePasswordResetToken {
  id          String    @id @default(uuid())
  locataireId String
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  locataire Locataire @relation(fields: [locataireId], references: [id], onDelete: Cascade)

  @@index([locataireId])
  @@index([tokenHash])
}

// ============================================================
// AUTHENTIFICATION PROPRIÉTAIRES
// ============================================================

enum StatutVerification {
  NOT_VERIFIED
  PENDING
  VERIFIED
  REJECTED
}

model VerificationDocuments {
  id             String @id @default(uuid())
  proprietaireId String @unique

  // Type de pièce d'identité
  typePiece String @default("CNI") // CNI | PASSEPORT | CARTE_CONSULAIRE | AUTRE

  // Documents
  pieceIdentiteRecto String? // URL Cloudinary - recto
  pieceIdentiteVerso String? // URL Cloudinary - verso (pour CNI)
  selfie             String? // URL Cloudinary

  // Consentement
  conditionsAcceptees Boolean @default(false)

  // Traitement admin
  motifRejet     String? // Motif de rejet (si rejeté)
  traitePar      String? // ID de l'admin qui a traité
  dateTraitement DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  proprietaire Proprietaire @relation(fields: [proprietaireId], references: [id], onDelete: Cascade)
}

model Proprietaire {
  id                 String             @id @default(uuid())
  prenom             String
  nom                String
  sexe               String?
  telephone          String             @unique
  email              String?            @unique
  password           String
  statutVerification StatutVerification @default(NOT_VERIFIED)
  verifiedAt         DateTime?

  // Vérification téléphone (OTP inscription)
  telephoneVerifie      Boolean   @default(false)
  telephoneOtp          String?
  telephoneOtpExpiresAt DateTime?

  // Suspension
  estSuspendu     Boolean   @default(false)
  motifSuspension String?
  dateSuspension  DateTime?
  suspenduPar     String?

  // Avertissements & escalade
  nbAvertissements      Int       @default(0)
  nbSignalementsValides Int       @default(0)
  estRestreint          Boolean   @default(false) // 3 avert : restriction temporaire
  dateFinRestriction    DateTime? // fin de la restriction (3 jours)
  dateFinSuspension     DateTime? // fin de suspension (1 mois) — remplace estSuspendu booléen
  estBanni              Boolean   @default(false) // 5 avert : bannissement permanent
  dateBannissement      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens       ProprietaireRefreshToken[]
  passwordResetTokens PasswordResetToken[]
  biens               Bien[]
  locataire           Locataire[]
  bails               BailLocation[]
  verification        VerificationDocuments?
  transactions        Transaction[]
  promotionHistories  PromotionHistory[]
  documentsBien       DocumentBien[]
  messagesInternes    MessageInterne[]
  bailInvitations     BailInvitation[]
  etatsDesLieux       EtatDesLieux[]
}

model MessageInterne {
  id             String   @id @default(uuid())
  proprietaireId String
  bailId         String?
  bienId         String?
  titre          String
  corps          String
  type           String   @default("INFO") // INFO | AVERTISSEMENT | SANCTION | LEVEE | PREAVIS | RESILIATION | FIN_BAIL
  lu             Boolean  @default(false)
  createdAt      DateTime @default(now())

  proprietaire Proprietaire @relation(fields: [proprietaireId], references: [id], onDelete: Cascade)

  @@index([proprietaireId])
  @@index([createdAt])
}

model MessageInterneLocataire {
  id          String   @id @default(uuid())
  locataireId String
  bailId      String?
  bienId      String?
  titre       String
  corps       String
  type        String   @default("INFO") // INFO | PREAVIS | RESILIATION | FIN_BAIL
  lu          Boolean  @default(false)
  createdAt   DateTime @default(now())

  locataire Locataire @relation(fields: [locataireId], references: [id], onDelete: Cascade)

  @@index([locataireId])
  @@index([createdAt])
}

model ProprietaireRefreshToken {
  id             String    @id @default(uuid())
  proprietaireId String
  tokenHash      String    @unique
  expiresAt      DateTime
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())

  proprietaire Proprietaire @relation(fields: [proprietaireId], references: [id], onDelete: Cascade)

  @@index([proprietaireId])
  @@index([tokenHash])
}

model PasswordResetToken {
  id             String    @id @default(uuid())
  proprietaireId String
  tokenHash      String    @unique
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime  @default(now())

  proprietaire Proprietaire @relation(fields: [proprietaireId], references: [id], onDelete: Cascade)

  @@index([proprietaireId])
  @@index([tokenHash])
}

// ============================================================
// AUTHENTIFICATION ADMIN
// ============================================================

model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String    @id @default(uuid())
  adminId   String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([tokenHash])
}

// ============================================================
// ALERTES (NOUVELLES ANNONCES)
// ============================================================

enum StatutAlerte {
  ACTIVE
  DESACTIVE
}

model Alerte {
  id              String  @id @default(uuid())
  telephone       String
  // Critères de recherche
  ville           String?
  quartier        String?
  typeLogement    String?
  typeTransaction String?
  prixMin         Int?
  prixMax         Int?

  canalPrefere String       @default("SMS") // SMS | WHATSAPP
  statut       StatutAlerte @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([telephone])
  @@index([statut])
}

// ============================================================
// TEMOIGNAGES
// ============================================================

// ============================================================
// HISTORIQUE DES TRANSACTIONS DE PAIEMENT
// ============================================================

enum TypePaiement {
  PAIEMENT_LOYER // Paiement de loyer par un locataire
  PAIEMENT_PREMIUM // Paiement pour mise en avant d'annonce
  PAIEMENT_PROMOTION // Paiement pour promotion d'annonce
  REMBOURSEMENT // Remboursement au propriétaire
  RESTITUTION_CAUTION // Restitution de caution au locataire
  COMMISSION_LOYER // Commission prélevée sur loyer
  MISE_EN_AVANT // Paiement de mise en avant (nouveau flux)
}

enum StatutTransaction {
  EN_ATTENTE // Initiation du paiement en cours
  CONFIRME // Paiement confirmé
  ECHEC // Paiement échoué
  ANNULE // Transaction annulée
  REMBOURSE // Montant remboursé
}

model Transaction {
  id             String @id @default(uuid())
  proprietaireId String

  // Type et statut
  type   TypePaiement
  statut StatutTransaction @default(EN_ATTENTE)

  // Montant et devise
  montant Float
  devise  String @default("XOF") // Franc CFA

  // Informations du paiement
  modePaiement  String // "Orange Money", "MTN", "Wave", "Moov", etc.
  provider      String? // Provider spécifique (optionnel)
  reference     String? // Référence de la transaction externe
  transactionId String? // ID de transaction du provider

  // Dates
  dateInitiation   DateTime  @default(now())
  dateConfirmation DateTime?
  dateEcheance     DateTime? // Pour les paiements de loyer

  // Lien avec les entités
  bienId      String?
  bailId      String?
  echeanceId  String?
  locataireId String?

  // Informations supplémentaires
  note         String?
  instructions String? // Instructions de paiement (pour les stubs)
  metadata     Json? // Données supplémentaires

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  proprietaire Proprietaire     @relation(fields: [proprietaireId], references: [id], onDelete: Cascade)
  bien         Bien?            @relation(fields: [bienId], references: [id], onDelete: SetNull)
  bail         BailLocation?    @relation(fields: [bailId], references: [id], onDelete: SetNull)
  echeance     EcheancierLoyer? @relation(fields: [echeanceId], references: [id], onDelete: SetNull)
  locataire    Locataire?       @relation(fields: [locataireId], references: [id], onDelete: SetNull)

  @@index([proprietaireId])
  @@index([type])
  @@index([statut])
  @@index([bienId])
  @@index([bailId])
  @@index([dateInitiation])
  @@index([transactionId])
}

model Temoignage {
  id         String   @id @default(uuid())
  nom        String
  temoignage String   @db.Text
  actif      Boolean  @default(true)
  ordre      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([actif])
}

// ============================================================
// HISTORIQUE DES MISES EN AVANT (PROMOTIONS)
// ============================================================

enum StatutPromotion {
  EN_ATTENTE // En attente de confirmation admin
  ACTIVE // Promotion en cours
  TERMINEE // Promotion terminée naturellement
  ARRETEE // Promotion arrêtée manuellement par le propriétaire
  EXPIREE // Promotion expirée (non utilisée)
}

model PromotionHistory {
  id             String  @id @default(uuid())
  bienId         String
  proprietaireId String
  transactionId  String? // Lien vers la transaction de paiement

  // Informations de la formule
  formuleId  String
  formuleNom String
  dureeJours Int
  montant    Float

  // Dates
  dateDebut     DateTime
  dateFin       DateTime // Date de fin prévue
  dateFinReelle DateTime? // Date de fin réelle (si arrêté avant)

  // Paiement
  modePaiement     String?
  reference        String?
  note             String?
  confirmeParAdmin Boolean   @default(false)
  dateConfirmation DateTime?

  // Statut
  statut     StatutPromotion @default(ACTIVE)
  motifArret String? // Motif de l'arrêt (si arrêté manuellement)

  // Jours restants au moment de l'arrêt
  joursRestants Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  bien         Bien         @relation(fields: [bienId], references: [id], onDelete: Cascade)
  proprietaire Proprietaire @relation(fields: [proprietaireId], references: [id], onDelete: Cascade)

  @@index([bienId])
  @@index([proprietaireId])
  @@index([statut])
  @@index([dateDebut])
}

// ============================================================
// MONÉTISATION - CONFIG
// ============================================================

model ConfigMonetisation {
  id                String   @id @default("config")
  miseEnAvantActive Boolean  @default(false)
  commissionActive  Boolean  @default(false)
  tauxCommission    Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ConfigSite {
  id                 String   @id @default("config_site")
  contactEmail       String   @default("contact@seek.sn")
  contactPhone       String   @default("+221 77 000 00 00")
  contactAddress     String   @default("Dakar, Sénégal")
  // Horaires du service client au format JSON
  // Structure: { "lundi": { "open": "08:00", "close": "18:00", "isOpen": true }, ... }
  serviceClientHours Json     @default("[{\"day\":\"lundi\",\"isOpen\":true,\"open\":\"08:00\",\"close\":\"18:00\"},{\"day\":\"mardi\",\"isOpen\":true,\"open\":\"08:00\",\"close\":\"18:00\"},{\"day\":\"mercredi\",\"isOpen\":true,\"open\":\"08:00\",\"close\":\"18:00\"},{\"day\":\"jeudi\",\"isOpen\":true,\"open\":\"08:00\",\"close\":\"18:00\"},{\"day\":\"vendredi\",\"isOpen\":true,\"open\":\"08:00\",\"close\":\"18:00\"},{\"day\":\"samedi\",\"isOpen\":true,\"open\":\"09:00\",\"close\":\"18:00\"},{\"day\":\"dimanche\",\"isOpen\":false,\"open\":\"09:00\",\"close\":\"13:00\"}]")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ============================================================
// INVITATIONS BAIL (locataire existant chez un autre propriétaire)
// ============================================================

enum StatutBailInvitation {
  PENDING
  ACCEPTEE
  REFUSEE
  EXPIREE
}

model BailInvitation {
  id             String @id @default(uuid())
  bienId         String
  locataireId    String
  proprietaireId String

  // Données du bail proposé
  typeBail           String?
  dateDebutBail      DateTime
  dateFinBail        DateTime?
  montantLoyer       Float
  montantCaution     Float?
  cautionVersee      Boolean   @default(false)
  jourLimitePaiement Int?
  renouvellement     Boolean   @default(true)
  frequencePaiement  String?

  // Invitation
  token     String               @unique @default(uuid())
  statut    StatutBailInvitation @default(PENDING)
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bien         Bien         @relation(fields: [bienId], references: [id], onDelete: Cascade)
  locataire    Locataire    @relation(fields: [locataireId], references: [id], onDelete: Cascade)
  proprietaire Proprietaire @relation(fields: [proprietaireId], references: [id], onDelete: Cascade)

  @@index([locataireId])
  @@index([proprietaireId])
  @@index([token])
  @@index([statut])
}

// ============================================================
// SIGNALEMENTS
// ============================================================

enum MotifSignalement {
  ARNAQUE
  INAPPROPRIE
  INDISPONIBLE
  FAUSSES_INFOS
  DOUBLON
  AUTRE
}

enum StatutSignalement {
  EN_ATTENTE
  VALIDE
  REJETE
}

model Signalement {
  id             String  @id @default(uuid())
  bienId         String
  comptePublicId String?

  nom         String
  telephone   String
  motif       MotifSignalement
  commentaire String?          @db.Text

  statut         StatutSignalement @default(EN_ATTENTE)
  traitePar      String? // ID de l'admin qui a traité
  dateTraitement DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bien         Bien          @relation(fields: [bienId], references: [id], onDelete: Cascade)
  comptePublic ComptePublic? @relation(fields: [comptePublicId], references: [id], onDelete: SetNull)

  @@index([bienId])
  @@index([comptePublicId])
  @@index([statut])
  @@index([telephone])
}

// ============================================================
// ETATS DES LIEUX
// ============================================================

enum TypeEtatDesLieux {
  ENTREE
  SORTIE
}

enum StatutEtatDesLieux {
  BROUILLON
  EN_ATTENTE_VALIDATION
  VALIDE
  CONTESTE
  EN_LITIGE
}

enum StatutContestationElement {
  EN_ATTENTE
  RECTIFIE
  RESERVE
  REFUSE
}

enum EtatElement {
  NEUF
  BON
  USAGE
  MAUVAIS
  DEGRADE
}

model EtatDesLieux {
  id             String @id @default(uuid())
  bailId         String
  bienId         String
  proprietaireId String
  locataireId    String

  type            TypeEtatDesLieux
  statut          StatutEtatDesLieux @default(BROUILLON)
  dateRealisation DateTime           @default(now())
  dateValidation  DateTime?

  documentPdf String?

  nbCles Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bail         BailLocation @relation(fields: [bailId], references: [id], onDelete: Cascade)
  bien         Bien         @relation(fields: [bienId], references: [id], onDelete: Cascade)
  proprietaire Proprietaire @relation(fields: [proprietaireId], references: [id], onDelete: Cascade)
  locataire    Locataire    @relation(fields: [locataireId], references: [id], onDelete: Cascade)

  pieces PieceEtatDesLieux[]

  @@unique([bailId, type])
  @@index([bienId])
  @@index([proprietaireId])
  @@index([locataireId])
  @@index([statut])
}

model PieceEtatDesLieux {
  id             String @id @default(uuid())
  etatDesLieuxId String
  nom            String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  etatDesLieux EtatDesLieux          @relation(fields: [etatDesLieuxId], references: [id], onDelete: Cascade)
  elements     ElementEtatDesLieux[]

  @@index([etatDesLieuxId])
}

model ElementEtatDesLieux {
  id          String      @id @default(uuid())
  pieceId     String
  nom         String
  etat        EtatElement
  commentaire String?     @db.Text
  photos      String[]

  // Contestation
  estConteste        Boolean                    @default(false)
  motifContestation  String?                    @db.Text
  photoContestation  String?
  statutContestation StatutContestationElement?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  piece PieceEtatDesLieux @relation(fields: [pieceId], references: [id], onDelete: Cascade)

  @@index([pieceId])
}
